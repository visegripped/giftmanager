# Environment Variables Template
# Copy this file to .env.local for local development

# Postgres (local Docker)
POSTGRES_URL=postgresql://giftmanager:giftmanager_local_password@localhost:5433/giftmanager
POSTGRES_PORT=5433
POSTGRES_DB=giftmanager
POSTGRES_USER=giftmanager
POSTGRES_PASSWORD=giftmanager_local_password

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here

# Facebook OAuth
NEXT_PUBLIC_FB_APP_ID=your_facebook_app_id_here
FB_APP_SECRET=your_facebook_app_secret_here

# Cron job protection (local dev — any value)
CRON_SECRET=local-dev-cron-secret

# App version (optional — defaults to package.json version)
NEXT_PUBLIC_APP_VERSION=2.0.0

# API URLs (same-origin by default; override only if needed)
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_REPORTING_API_URL=/api/reporting
